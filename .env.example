# Copy to .env.local for development. In Vercel: Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: Stripe Checkout + webhooks (never expose the secret key or service role to the client)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional fallback when Host / X-Forwarded-* headers are missing (e.g. some local proxies)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# RapidAPI — Aliexpress True API (server-only; rotate if exposed)
# RAPIDAPI_KEY=your_rapidapi_key
# ALIEXPRESS_RAPIDAPI_HOST=aliexpress-true-api.p.rapidapi.com
# ALIEXPRESS_HOT_PRODUCTS_PATH=/api/v3/hot-products-download
# Import pricing: sale_price = original_price × 1.35 × 1.19 (German VAT) — see lib/aliexpress/parse-products.ts
# Secret for POST /api/integrations/aliexpress/import (Bearer token)
# ALIEXPRESS_IMPORT_SECRET=generate_a_long_random_string
